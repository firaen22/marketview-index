{
    "crons": [
        {
            "path": "/api/cron/update-market-data",
            "schedule": "30 1 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}